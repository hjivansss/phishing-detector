{
  "manifest_version": 3,
  "name": "Phishing Detector",
  "version": "1.0",
  "description": "Detect phishing websites using URL and blacklist API",

  "permissions": ["tabs", "storage", "unlimitedStorage", "webNavigation"],

  "host_permissions": [
    "https://openphish.com/*",
    "https://urlhaus.abuse.ch/*",
    "https://raw.githubusercontent.com/*"
  ],

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Phishing Detector"
  }
}
